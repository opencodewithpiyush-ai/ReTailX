<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".fragments.EmployeeDashboardFragment">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/circular_spotify"
        android:maxLines="2"
        android:text="Welcome \nEmployee!"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/ivProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivProfile"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/round_account_circle_24"
        app:layout_constraintBottom_toBottomOf="@+id/tvWelcome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

    <!-- Content Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="24dp">
        
    <LinearLayout
        android:id="@+id/llDashboardOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Store Manager & Inventory Manager & Sales Exec Options -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewProducts"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="View Products"
            android:visibility="gone"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
             android:id="@+id/btnManageProducts"
             android:layout_width="match_parent"
             android:layout_height="60dp"
             android:text="Manage Products"
             android:visibility="gone"
             app:cornerRadius="12dp"
             android:backgroundTint="@color/design_default_color_primary"
             android:layout_marginBottom="12dp"/>

        <!-- Inventory Manager Options -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewOrders"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="View Orders"
            android:visibility="gone"
            app:cornerRadius="12dp"
             android:layout_marginBottom="12dp"/>
             
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageOrders"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Manage Orders"
            android:visibility="gone"
            app:cornerRadius="12dp"
             android:layout_marginBottom="12dp"/>

        <!-- Sales Executive Options -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateOrder"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Create New Order"
            android:visibility="gone"
            app:cornerRadius="12dp"
            android:backgroundTint="@android:color/holo_green_dark"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalesPerformance"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Sales Performance"
            android:visibility="gone"
            app:cornerRadius="12dp"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
