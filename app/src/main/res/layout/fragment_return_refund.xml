<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:title="Returns &amp; Refunds" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Section -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search by Bill ID, Customer Phone or Name"
                app:startIconDrawable="@drawable/search_24"
                app:endIconMode="clear_text"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearchBill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:fontFamily="@font/montserrat_regular"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchBill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search Bill"
                android:fontFamily="@font/circular_spotify"
                android:layout_marginTop="8dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- Loading Indicator -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- Bill Details Card (Initially Hidden) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBillDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                style="@style/Widget.Material3.CardView.Elevated">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Original Bill"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/circular_spotify"
                        android:textColor="?attr/colorPrimary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvBillId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bill ID: --"
                                android:textSize="13sp"
                                android:fontFamily="@font/montserrat_regular" />

                            <TextView
                                android:id="@+id/tvBillCustomer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Customer: --"
                                android:textSize="13sp"
                                android:fontFamily="@font/montserrat_regular"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/tvBillPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone: --"
                                android:textSize="13sp"
                                android:fontFamily="@font/montserrat_regular"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tvBillDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date: --"
                                android:textSize="12sp"
                                android:fontFamily="@font/montserrat_regular"
                                android:textColor="?android:textColorSecondary" />

                            <TextView
                                android:id="@+id/tvBillTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/circular_spotify"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:id="@+id/tvBillStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Paid"
                                android:textSize="12sp"
                                android:fontFamily="@font/circular_spotify"
                                android:textColor="#2E7D32"
                                android:background="@drawable/bg_role_badge"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Select Items to Return -->
            <TextView
                android:id="@+id/tvSelectItemsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Items to Return"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/circular_spotify"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReturnItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:listitem="@layout/item_return_item" />

            <!-- Refund Reason -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Refund Reason"
                android:visibility="gone"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                <AutoCompleteTextView
                    android:id="@+id/actvReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:fontFamily="@font/montserrat_regular"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Refund Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRefundSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFF3E0"
                style="@style/Widget.Material3.CardView.Filled">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Refund Summary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/circular_spotify"
                        android:textColor="#E65100" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Items Selected"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_regular" />

                        <TextView
                            android:id="@+id/tvItemsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/circular_spotify" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal Refund"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_regular" />

                        <TextView
                            android:id="@+id/tvRefundSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="14sp"
                            android:fontFamily="@font/circular_spotify" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutTaxReversal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvTaxReversalLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tax Reversal"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_regular" />

                        <TextView
                            android:id="@+id/tvTaxReversalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="14sp"
                            android:fontFamily="@font/circular_spotify" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#FFCC80"
                        android:layout_marginVertical="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Refund"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/circular_spotify"
                            android:textColor="#D32F2F" />

                        <TextView
                            android:id="@+id/tvTotalRefund"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/circular_spotify"
                            android:textColor="#D32F2F" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProcessRefund"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Process Refund"
                android:textSize="16sp"
                android:fontFamily="@font/circular_spotify"
                android:visibility="gone"
                app:cornerRadius="12dp"
                app:icon="@drawable/rounded_assignment_return_24"
                app:iconGravity="textStart"
                android:backgroundTint="#D32F2F" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewHistory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="View Refund History"
                android:textSize="14sp"
                android:fontFamily="@font/circular_spotify"
                app:cornerRadius="8dp"
                app:icon="@drawable/baseline_history_24"
                app:iconGravity="textStart"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
