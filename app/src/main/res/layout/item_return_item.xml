<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    style="@style/Widget.Material3.CardView.Filled">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <CheckBox
            android:id="@+id/cbSelectItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvReturnProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/circular_spotify"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvReturnUnitPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="13sp"
                android:fontFamily="@font/montserrat_regular"
                android:textColor="?android:textColorSecondary" />

            <TextView
                android:id="@+id/tvOriginalQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bought: 0"
                android:textSize="12sp"
                android:fontFamily="@font/montserrat_regular"
                android:textColor="?android:textColorSecondary" />

        </LinearLayout>

        <!-- Quantity Picker -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">

            <ImageButton
                android:id="@+id/btnMinus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/baseline_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Decrease"
                android:scaleType="centerInside"
                app:tint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tvReturnQty"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/circular_spotify"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnPlus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Increase"
                android:scaleType="centerInside"
                app:tint="?attr/colorPrimary" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvItemRefundAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/circular_spotify"
            android:textColor="#D32F2F"
            android:minWidth="60dp"
            android:gravity="end" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
