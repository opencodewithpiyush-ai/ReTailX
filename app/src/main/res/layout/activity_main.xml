<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".auth.MainActivity">

    <!-- Top Bar with Info Icon -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cardInfo"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        app:icon="@drawable/rounded_info_24"
        app:iconSize="24dp"
        app:iconTint="?attr/colorOnSurfaceVariant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App Logo / Header Static (Optional, keeping it clean as per request) --> 
    <!-- We will let the ViewPager content shine, but we need to ensure the ViewPager 
         doesn't overlap the Info button or the bottom buttons area. -->

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/tabLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardInfo" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@android:color/transparent"
        app:tabBackground="@android:color/transparent"
        app:tabRippleColor="@null"
        app:tabGravity="center"
        app:tabIndicatorHeight="0dp"
        app:tabMinWidth="0dp"
        app:tabPaddingStart="8dp"
        app:tabPaddingEnd="8dp"
        app:layout_constraintBottom_toTopOf="@+id/loginBusinessBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Progress Bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/loginBusinessBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Business Login Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/loginBusinessBtn"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/circular_spotify"
        android:text="@string/business_login"
        android:textAllCaps="false"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="8dp"
        app:icon="@drawable/baseline_business_24"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="24dp"
        app:layout_constraintBottom_toTopOf="@+id/loginCustomerBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Customer Login Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/loginCustomerBtn"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/circular_spotify"
        android:text="@string/login_as_customer"
        android:textAllCaps="false"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="8dp"
        app:icon="@drawable/baseline_person_24"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>